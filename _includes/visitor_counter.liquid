<style>
  .visitor-counter {
    max-width: 960px;
    margin: 2.5rem auto 0;
    padding: 1.5rem 1rem 0;
    border-top: 1px solid var(--global-divider-color);
    text-align: center;
    background: var(--global-bg-color);
    border-radius: 6px;
  }
</style>

<div id="visitor-counter" class="visitor-counter">
  <a
    href="https://info.flagcounter.com/yz2H"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="View detailed visitor statistics"
  >
    <img
      src="https://s01.flagcounter.com/count2/yz2H/bg_FFFFFF/txt_666666/border_CCCCCC/columns_3/maxflags_12/viewers_0/labels_1/pageviews_1/flags_0/percent_0/"
      alt="Visitors by country"
      loading="lazy"
      style="
        max-width: 100%;
        height: auto;
        border: 0;
      "
    >
  </a>
</div>
<script>
  (function () {
    function moveVisitorCounter() {
      var counter = document.getElementById('visitor-counter');
      var footer = document.querySelector('footer');

      if (!counter) {
        return;
      }

      if (footer && footer.parentNode) {
        footer.parentNode.insertBefore(counter, footer);
      } else {
        document.body.appendChild(counter);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', moveVisitorCounter);
    } else {
      moveVisitorCounter();
    }

    window.addEventListener('load', moveVisitorCounter);
  })();
</script>
